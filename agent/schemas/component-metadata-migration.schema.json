{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ds-mo.dev/schemas/component-metadata-migration.schema.json",
  "title": "Temporary CompoMo component metadata migration baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "description",
    "artifactExceptions",
    "legacySummaries",
    "missingAgentMetadata",
    "metadataRefactors"
  ],
  "properties": {
    "$schema": { "const": "../schemas/component-metadata-migration.schema.json" },
    "schemaVersion": { "const": "1.0.0" },
    "description": { "type": "string", "minLength": 1 },
    "artifactExceptions": {
      "type": "object",
      "propertyNames": { "pattern": "^component:ds-[a-z0-9-]+$" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "minProperties": 1,
        "properties": {
          "style": { "type": "string", "minLength": 1 },
          "story": { "type": "string", "minLength": 1 }
        }
      }
    },
    "legacySummaries": {
      "type": "object",
      "propertyNames": { "pattern": "^component:ds-[a-z0-9-]+$" },
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "missingAgentMetadata": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^component:ds-[a-z0-9-]+$" }
    },
    "metadataRefactors": {
      "type": "object",
      "propertyNames": { "pattern": "^component:ds-[a-z0-9-]+$" },
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}
