            "required": false
          }
        }
      },
      "dependencies": [
        "@ds-mo/ui",
        "@ds-mo/tokens",
        "@ds-mo/icons"
      ],
      "registryDependencies": [
        "text",
        "button-unfilled",
        "button-filled"
