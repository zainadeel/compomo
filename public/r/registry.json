          "icon": {
            "type": "string",
            "required": false
          },
          "intent": {
            "type": "'neutral' | 'brand' | 'ai' | 'negative' | 'warning' | 'caution' | 'positive' | 'guide' | 'walkthrough'",
            "required": false
          },
          "contrast": {
            "type": "'bold' | 'strong' | 'medium' | 'faint'",
            "required": false
