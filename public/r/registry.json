{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "compomo",
  "homepage": "https://zainadeel.github.io/compomo/",
  "description": "CompoMo (@ds-mo/ui) — framework-agnostic web component library built with Stencil.js. Styled with TokoMo design tokens. Works with React 17+, Angular 12+, and plain HTML. Distributed as an npm package; not copy-paste.",
  "meta": {
    "distribution": "npm",
    "install": "npm install @ds-mo/ui @ds-mo/tokens @ds-mo/icons",
    "register": "import '@ds-mo/ui/dist/components/ds-button-filled.js'; // import each <ds-*> tag you use",
    "cssSetup": "import '@ds-mo/tokens';\nimport '@ds-mo/tokens/reset';\nimport '@ds-mo/tokens/globals';",
    "themeSetup": "Set data-theme=\"dark\" on <html> for dark mode. Light is default.",
    "peerDependencies": {
      "required": [
        "@ds-mo/tokens >=2.9.0",
        "@ds-mo/icons ^5.0.1"
      ],
      "optional": [],
      "frameworks": "None required — works with any framework that supports Custom Elements."
    }
  },
  "items": [
    {
      "name": "text",
      "title": "Text",
      "description": "Typography primitive supporting all design-system text variants, colors, truncation, and wrapping.",
      "type": "registry:ui",
      "meta": {
        "library": "@ds-mo/ui",
        "distribution": "npm",
        "storybook": "https://zainadeel.github.io/compomo/?path=/story/text",
        "exports": [
          "Text"
        ],
        "props": {
          "variant": {
            "type": "TextVariant",
            "required": false
          },
          "children": {
            "type": "React.ReactNode",
            "required": true
          },
          "color": {
            "type": "TextColor",
            "required": false
          },
          "as": {
            "type": "'p' | 'span' | 'div' | 'label' | 'h1'-'h6'",
            "required": false
          },
          "lineTruncation": {
            "type": "1 | 2 | 3 | 4 | 5 | \"none\"",
            "required": false
          },
          "decoration": {
            "type": "'none' | 'underline' | 'dotted-underline'",
            "required": false
          },
          "italic": {
            "type": "boolean",
            "required": false
          },
          "align": {
            "type": "'left' | 'center' | 'right'",
            "required": false
          },
          "wrap": {
            "type": "'wrap' | 'nowrap' | 'balance' | 'pretty'",
            "required": false
          }
        }
      },
      "dependencies": [
        "@ds-mo/ui",
        "@ds-mo/tokens"
      ],
      "registryDependencies": []
    },
    {
