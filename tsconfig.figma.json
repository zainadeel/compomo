{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["@figma/code-connect/figma-types"]
  },
  "include": [
    "code-connect/published/**/*.figma.ts",
    "code-connect/examples/**/*.figma.ts"
  ]
}
