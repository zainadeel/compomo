{
  "name": "@ds-mo/ui",
  "version": "0.2.0",
  "description": "CompoMo — composable React UI components styled with TokoMo design tokens",
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "component-library",
    "css-modules",
    "typescript"
  ],
  "homepage": "https://github.com/zainadeel/compomo#readme",
  "bugs": "https://github.com/zainadeel/compomo/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/zainadeel/compomo.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/index.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "npm run registry:build && storybook dev -p 6006",
    "storybook:build": "npm run registry:build && storybook build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "registry:build": "node scripts/build-registry.mjs",
    "mcp": "node scripts/mcp-server.mjs"
  },
  "peerDependencies": {
    "@ds-mo/tokens": ">=0.3.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "@ds-mo/icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ds-mo/icons": "^0.5.0",
    "@ds-mo/tokens": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.3.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
