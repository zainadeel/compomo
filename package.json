{
  "name": "@ds-mo/ui",
  "version": "2.10.0",
  "description": "CompoMo — composable web components styled with TokoMo design tokens",
  "keywords": [
    "web-components",
    "custom-elements",
    "react",
    "angular",
    "components",
    "ui",
    "design-system",
    "component-library",
    "typescript"
  ],
  "homepage": "https://zainadeel.github.io/compomo/",
  "bugs": "https://github.com/zainadeel/compomo/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/zainadeel/compomo.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/wc/components.d.ts",
  "exports": {
    ".": {
      "types": "./src/wc/components.d.ts",
      "import": "./dist/components/index.js"
    },
    "./angular": {
      "types": "./src/angular/index.ts",
      "import": "./src/angular/index.ts"
    },
    "./react": {
      "types": "./src/react/components.ts",
      "import": "./src/react/components.ts"
    },
    "./dist/components": {
      "types": "./src/wc/components.d.ts",
      "import": "./dist/components/index.js"
    },
    "./nav": {
      "types": "./src/wc/nav/index.ts",
      "import": "./src/wc/nav/index.ts"
    },
    "./utils": {
      "types": "./src/wc/utils/index.ts",
      "import": "./src/wc/utils/index.ts"
    },
    "./dist/components/*": "./dist/components/*"
  },
  "files": [
    "dist",
    "src/wc/components.d.ts",
    "src/wc/components/**/*.ts",
    "src/wc/components/**/*.tsx",
    "!src/wc/components/**/*.stories.ts",
    "!src/wc/components/**/*.stories.tsx",
    "src/wc/nav",
    "src/wc/utils",
    "src/angular",
    "src/react"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-icon-catalog.mjs",
    "pretypecheck": "node scripts/generate-icon-catalog.mjs",
    "pretest": "node scripts/generate-icon-catalog.mjs",
    "build": "stencil build && node scripts/patch-index-types.mjs && node scripts/patch-components-d-exports.mjs && node scripts/verify-icons-externalized.mjs && node scripts/write-build-stamp.mjs",
    "verify:pack": "node scripts/verify-npm-pack.mjs && node scripts/verify-nav-import.mjs",
    "test": "node --import tsx/esm --test tests/panel-nav-utils.test.ts tests/panel-tools.test.ts tests/shell-shortcuts.test.ts tests/shell-gradient-presets.test.ts tests/shell-view-transition.test.ts tests/shell-gradient.test.ts tests/shell-chrome-metrics.test.ts tests/shell-chrome-layer.test.ts tests/chrome-transition.test.ts tests/bar-nav-overflow-hysteresis.test.ts tests/badge-gradient-ring.test.ts tests/scroll-edge-fade.test.ts tests/resolve-css-length-px.test.ts tests/resolve-css-time-ms.test.ts tests/overlay-positioning.test.ts tests/menu-position.test.ts tests/menu-placement.test.ts tests/bar-nav-utils.test.ts tests/bar-nav-tabs-menu-utils.test.ts tests/bar-nav-dom-utils.test.ts tests/icon-catalog.test.ts tests/icon-cache.test.ts tests/icon-svg.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:install": "playwright install chromium",
    "build:docs": "stencil build --docs",
    "dev": "node scripts/generate-icon-catalog.mjs && stencil build --watch",
    "storybook:ui": "node scripts/storybook-ui.mjs",
    "prestorybook:build": "node scripts/write-build-stamp.mjs",
    "storybook": "node scripts/storybook-dev.mjs",
    "storybook:build": "storybook build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "registry:build": "node scripts/build-registry.mjs",
    "mcp": "node scripts/mcp-server.mjs",
    "figma:connect:help": "figma connect --help",
    "figma:connect:publish:dry-run": "figma connect publish --dry-run -c figma.config.json --exit-on-unreadable-files",
    "figma:connect:publish": "figma connect publish -c figma.config.json --exit-on-unreadable-files",
    "figma:connect:preview": "figma connect preview -c figma.config.json",
    "typecheck:figma": "tsc -p tsconfig.figma.json --noEmit"
  },
  "peerDependencies": {
    "@ds-mo/icons": "^6.0.0",
    "@ds-mo/tokens": ">=2.9.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ds-mo/icons": "^6.1.1",
    "@ds-mo/tokens": "^2.12.1",
    "@eslint/js": "^10.0.1",
    "@figma/code-connect": "^1.4.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.55.0",
    "@stencil/angular-output-target": "^1.3.1",
    "@stencil/core": "^4.43.4",
    "@stencil/react-output-target": "^1.5.3",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/web-components": "^10.4.2",
    "@storybook/web-components-vite": "^10.4.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "lit": "^3.3.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.2",
    "tsx": "^4.20.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "sideEffects": [
    "**/*.css",
    "dist/components/**/*.js"
  ]
}
