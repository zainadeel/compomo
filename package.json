{
  "name": "@ds-mo/ui",
  "version": "1.0.0",
  "description": "CompoMo — composable web components styled with TokoMo design tokens",
  "keywords": [
    "web-components",
    "custom-elements",
    "react",
    "angular",
    "components",
    "ui",
    "design-system",
    "component-library",
    "typescript"
  ],
  "homepage": "https://zainadeel.github.io/compomo/",
  "bugs": "https://github.com/zainadeel/compomo/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/zainadeel/compomo.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/components/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./angular": {
      "import": "./src/angular/index.ts"
    },
    "./dist/components/*": "./dist/components/*"
  },
  "files": [
    "dist",
    "src/angular"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-icon-catalog.mjs",
    "pretypecheck": "node scripts/generate-icon-catalog.mjs",
    "pretest": "node scripts/generate-icon-catalog.mjs",
    "build": "stencil build && node scripts/patch-index-types.mjs && node scripts/verify-icons-externalized.mjs",
    "test": "node --import tsx/esm --test tests/panel-nav-utils.test.ts tests/bar-nav-utils.test.ts tests/bar-nav-tabs-menu-utils.test.ts tests/bar-nav-dom-utils.test.ts tests/icon-catalog.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:install": "playwright install chromium",
    "build:docs": "stencil build --docs",
    "dev": "node scripts/generate-icon-catalog.mjs && stencil build --dev --watch",
    "storybook": "stencil build && storybook dev -p 6006",
    "storybook:build": "storybook build",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "registry:build": "node scripts/build-registry.mjs",
    "mcp": "node scripts/mcp-server.mjs"
  },
  "peerDependencies": {
    "@ds-mo/icons": "^5.0.1",
    "@ds-mo/tokens": ">=2.9.0"
  },
  "devDependencies": {
    "@ds-mo/icons": "^5.0.1",
    "@ds-mo/tokens": "^2.9.0",
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.55.0",
    "@stencil/angular-output-target": "^1.3.1",
    "@stencil/core": "^4.43.4",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/web-components": "^10.4.2",
    "@storybook/web-components-vite": "^10.4.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "lit": "^3.3.3",
    "storybook": "^10.4.2",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "sideEffects": [
    "**/*.css",
    "dist/components/**/*.js"
  ]
}
